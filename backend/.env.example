# STM developer portal: https://portail.developpeurs.stm.info/apihub/
# Subscribe to "Données Ouverte iBUS - GTFS-Realtime (v2.0)" and copy your credentials.
# Copy this file to .env in this folder and fill in values. Do not commit .env.
# Publish your application after adding the API; keys are inactive until published.
# If you see HTTP 400, the response body is often "Invalid API Key" (STM uses 400, not 401).
# Use the key value only — no quotes around it in .env.

STM_API_KEY=
STM_SHARED_SECRET=
